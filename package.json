{
  "name": "school-manager",
  "description": "School Manager ERP — student, staff, attendance and finance management",
  "author": "Md. Al Amin Hossain <alaminjava@gmail.com>",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "client": "vite --config client/vite.config.js",
    "dev": "node scripts/dev.js",
    "server": "node server/server.js",
    "prebuild": "node scripts/ensure-deps.js",
    "build": "vite build --config client/vite.config.js",
    "lint": "eslint .",
    "preview": "vite preview --config client/vite.config.js",
    "start": "node server/server.js",
    "seed:sections": "node scripts/seedSections.cjs",
    "render-build": "npm ci && npm run build",
    "electron:dev": "cross-env NODE_ENV=development concurrently -k \"npm run server\" \"npm run client\" \"wait-on http://localhost:5001/api/health && electron .\"",
    "electron:build": "npm run build && electron-builder --config electron-builder.yml",
    "electron:pack": "npm run build && electron-builder --dir --config electron-builder.yml",
    "electron:start": "electron ."
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^8.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tailwindcss": "^4.2.4",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "nodemon": "^3.1.14",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=10"
  },
  "mongodbMemoryServer": {
    "version": "7.0.14",
    "arch": "x64",
    "skipMD5": true
  }
}
